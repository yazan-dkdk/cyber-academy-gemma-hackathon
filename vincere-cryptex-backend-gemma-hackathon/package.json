{
  "name": "cyber-academy-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "lint": "node node_modules/typescript/bin/tsc --noEmit",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "prisma:generate": "node node_modules/prisma/build/index.js generate",
    "prisma:migrate:dev": "node node_modules/prisma/build/index.js migrate dev",
    "prisma:migrate:deploy": "node node_modules/prisma/build/index.js migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-fastify": "^11.1.3",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nodemailer": "^8.0.7",
    "otplib": "^12.0.1",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
