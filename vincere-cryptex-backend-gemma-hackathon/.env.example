NODE_ENV=development
PORT=3000
TRUST_PROXY=false
APP_BASE_URL=http://localhost:3005
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_NAME=Cyber Academy Web
DATABASE_URL=postgresql://user:password@localhost:5432/cyber_academy
REDIS_URL=redis://localhost:6379
SESSION_SECRET=your_session_secret_here
SESSION_COOKIE_NAME=sid
COOKIE_SECURE=false
COOKIE_DOMAIN=
SESSION_TTL_SECONDS=604800
SESSION_IDLE_TTL_SECONDS=1800
AUTH_STATE_CACHE_TTL_SECONDS=90
MFA_ENCRYPTION_KEY=your_mfa_encryption_key_here
MFA_ISSUER=Cyber Academy Web
PASSWORD_RESET_TOKEN_TTL_MINUTES=your_password_reset_token_ttl_minutes_here
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=your_email_verification_token_ttl_hours_here
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
REGISTER_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600
RESEND_VERIFICATION_RATE_LIMIT_MAX=5
RESEND_VERIFICATION_RATE_LIMIT_WINDOW_SECONDS=3600
FORGOT_PASSWORD_RATE_LIMIT_MAX=your_forgot_password_rate_limit_max_here
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=your_forgot_password_rate_limit_window_seconds_here
RESET_PASSWORD_RATE_LIMIT_MAX=your_reset_password_rate_limit_max_here
RESET_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=your_reset_password_rate_limit_window_seconds_here
FORGOT_PASSWORD_MIN_DURATION_MS=your_forgot_password_min_duration_ms_here
FLAG_SUBMISSION_RATE_LIMIT_MAX=10
FLAG_SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=300
LAB_START_RATE_LIMIT_MAX=5
LAB_START_RATE_LIMIT_WINDOW_SECONDS=300
LAB_RESET_RATE_LIMIT_MAX=10
LAB_RESET_RATE_LIMIT_WINDOW_SECONDS=300
LAB_TERMINATE_RATE_LIMIT_MAX=10
LAB_TERMINATE_RATE_LIMIT_WINDOW_SECONDS=300
MFA_ATTEMPT_MAX_FAILURES=5
MFA_ATTEMPT_WINDOW_SECONDS=300
MFA_ATTEMPT_LOCK_SECONDS=900
LAB_ORCHESTRATOR_BASE_URL=http://localhost:4000
LAB_ORCHESTRATOR_API_KEY=your_lab_orchestrator_api_key_here
LAB_ORCHESTRATOR_TIMEOUT_MS=10000
LAB_PROXY_BASE_URL=http://localhost:4001
GEMMA_PROVIDER=ollama
GEMMA_API_KEY=your_google_ai_studio_key_here
GEMMA_MODEL=gemma-2b-it
OLLAMA_ENABLED=true
