# Local development example values only. Do not commit real secrets.

NODE_ENV=development
PORT=3000
TRUST_PROXY=false
APP_BASE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001
APP_NAME=Vincere Cryptex

# Local services
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cyber_academy
REDIS_URL=redis://localhost:6379

# Session and auth examples
SESSION_SECRET=dev_example_session_secret_change_me_please_123456
SESSION_COOKIE_NAME=sid
COOKIE_SECURE=false
COOKIE_DOMAIN=
SESSION_TTL_SECONDS=604800
SESSION_IDLE_TTL_SECONDS=1800
AUTH_STATE_CACHE_TTL_SECONDS=90
MFA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
MFA_ISSUER=Vincere Cryptex
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Rate limits
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
REGISTER_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600
RESEND_VERIFICATION_RATE_LIMIT_MAX=5
RESEND_VERIFICATION_RATE_LIMIT_WINDOW_SECONDS=3600
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=3600
RESET_PASSWORD_RATE_LIMIT_MAX=5
RESET_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=900
FORGOT_PASSWORD_MIN_DURATION_MS=400
FLAG_SUBMISSION_RATE_LIMIT_MAX=10
FLAG_SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=300
LAB_START_RATE_LIMIT_MAX=5
LAB_START_RATE_LIMIT_WINDOW_SECONDS=300
LAB_RESET_RATE_LIMIT_MAX=10
LAB_RESET_RATE_LIMIT_WINDOW_SECONDS=300
LAB_TERMINATE_RATE_LIMIT_MAX=10
LAB_TERMINATE_RATE_LIMIT_WINDOW_SECONDS=300
MFA_ATTEMPT_MAX_FAILURES=5
MFA_ATTEMPT_WINDOW_SECONDS=300
MFA_ATTEMPT_LOCK_SECONDS=900

# Future lab orchestrator preview values
LAB_ORCHESTRATOR_BASE_URL=http://localhost:4000
LAB_ORCHESTRATOR_API_KEY=dev_example_lab_orchestrator_key
LAB_ORCHESTRATOR_TIMEOUT_MS=10000
LAB_PROXY_BASE_URL=http://localhost:4001

# AI Tutor local-first setup
GEMMA_PROVIDER=ollama
GEMMA_API_KEY=
GEMMA_MODEL=
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma-local
OLLAMA_TIMEOUT_MS=60000
GEMINI_ENABLED=false
AI_PROVIDER_PRIORITY=local-first

# Email delivery. Development can leave SMTP/Resend credentials blank.
EMAIL_PROVIDER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@example.com
RESEND_API_KEY=
